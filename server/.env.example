# ClipGenius Server Configuration

# Server Port
PORT=3000

# Google Cloud Video Intelligence API
# Get credentials from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# Note: Create a service account in Google Cloud Console
# 1. Go to https://console.cloud.google.com/iam-admin/serviceaccounts
# 2. Create a service account with "Video Intelligence API User" role
# 3. Download the JSON key file and rename to google-credentials.json
# 4. Enable Video Intelligence API at https://console.cloud.google.com/apis/library/video-intelligence.googleapis.com